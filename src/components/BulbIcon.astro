---
// The MiU mark: a network-node bulb replacing the lowercase "i" in the
// wordmark — gold nodes fused into a circuit mesh, on a navy (or white,
// when reversed) filament base. Per Brand Guidelines v1.0 / 02 Logo System.
interface Props {
  light?: boolean;
}
const { light = false } = Astro.props;
const baseColor = light ? '#FFFFFF' : '#16232E';
---

<svg class="bulb-icon" viewBox="0 0 40 52" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <g stroke={light ? 'rgba(255,255,255,.55)' : '#98A3AC'} stroke-width="0.9" fill="none">
    <line x1="20" y1="4" x2="12" y2="9" />
    <line x1="20" y1="4" x2="28" y2="8" />
    <line x1="12" y1="9" x2="7" y2="16" />
    <line x1="12" y1="9" x2="20" y2="14" />
    <line x1="28" y1="8" x2="20" y2="14" />
    <line x1="28" y1="8" x2="32" y2="15" />
    <line x1="7" y1="16" x2="11" y2="23" />
    <line x1="7" y1="16" x2="20" y2="14" />
    <line x1="20" y1="14" x2="11" y2="23" />
    <line x1="20" y1="14" x2="23" y2="21" />
    <line x1="32" y1="15" x2="23" y2="21" />
    <line x1="32" y1="15" x2="30" y2="25" />
    <line x1="11" y1="23" x2="18" y2="28" />
    <line x1="23" y1="21" x2="18" y2="28" />
    <line x1="23" y1="21" x2="30" y2="25" />
    <line x1="30" y1="25" x2="18" y2="28" />
  </g>
  <g fill="#C9A227">
    <circle cx="20" cy="4" r="1.6" />
    <circle cx="12" cy="9" r="2.1" />
    <circle cx="28" cy="8" r="1.5" />
    <circle cx="7" cy="16" r="2.4" />
    <circle cx="20" cy="14" r="1.7" />
    <circle cx="32" cy="15" r="2.2" />
    <circle cx="11" cy="23" r="2.6" />
    <circle cx="23" cy="21" r="1.5" />
    <circle cx="30" cy="25" r="2" />
    <circle cx="18" cy="28" r="1.9" />
  </g>
  <g fill={baseColor}>
    <rect x="7" y="34" width="26" height="2.4" rx="1.2" />
    <rect x="11" y="39" width="18" height="2.4" rx="1.2" />
    <rect x="15" y="44" width="10" height="2.4" rx="1.2" />
    <path d="M17 49 L23 49 L20 52 Z" />
  </g>
</svg>
