---
// Banner-style hero (BC Mongolia template pattern): a calm statement band —
// eyebrow, headline, positioning subtext — with no CTA in the hero itself;
// the first actionable button sits in the Vision section immediately below.
import { getDict } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

interface Props { locale: Locale }
const { locale } = Astro.props as Props;
const dict = getDict(locale);
const h = dict.home;
---

<section class="hero hero-home">
  <div class="hero-motif" aria-hidden="true">
    <svg class="hero-motif-svg" viewBox="0 0 1200 500" preserveAspectRatio="xMidYMid slice">
      <path class="hero-motif-line" d="M -20 90 L 200 90 L 200 40 L 480 40 L 480 100 L 780 100 L 780 20 L 1220 20" />
      <path class="hero-motif-line" d="M -20 380 L 260 380 L 260 320 L 540 320 L 540 420 L 860 420 L 860 300 L 1220 300" />
    </svg>
  </div>

  <div class="wrap hero-inner">
    <span class="eyebrow">{h.eyebrow}</span>
    <h1 class="hero-title">{h.positioning}</h1>
    <p class="hero-subtitle">{h.positioningSub}</p>
  </div>
</section>
