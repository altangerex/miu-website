---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout locale="mn" title="404">
  <section class="hero hero-page">
    <div class="wrap hero-inner" style="text-align:center;">
      <span class="eyebrow" style="justify-content:center;">404</span>
      <h1 class="hero-title" style="margin-left:auto;margin-right:auto;">Хуудас олдсонгүй / Page not found</h1>
      <p class="hero-subtitle" style="margin-left:auto;margin-right:auto;">
        <a href="/mn/" style="color:#C9A227; font-weight:700;">Нүүр хуудас руу буцах</a>
        &nbsp;·&nbsp;
        <a href="/en/" style="color:#C9A227; font-weight:700;">Back to homepage</a>
      </p>
    </div>
  </section>
</BaseLayout>
