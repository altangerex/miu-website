---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, getDict, localeStaticPaths, localizedPath } from '../../../i18n/utils';
import type { Locale } from '../../../i18n/utils';

export function getStaticPaths() {
  return localeStaticPaths();
}

interface Props { locale: Locale }
const { locale } = Astro.props as Props;
const { t } = useTranslations(locale);
const dict = getDict(locale);
const c = dict.contact;
const ex = dict.home.explorer;
const nextPath = localizedPath(locale, '/contact');
---

<BaseLayout locale={locale} title={t('nav.contact')} active="contact">
  <section class="hero hero-page">
    <div class="wrap hero-inner">
      <span class="eyebrow">{c.eyebrow}</span>
      <h1 class="hero-title">{c.heroTitle}</h1>
      <p class="hero-subtitle">{c.heroSubtitle}</p>
    </div>
  </section>

  <section id="form">
    <div class="wrap">
      <div class="contact-grid">
        <div class="contact-info-card">
          <h3>{c.infoTitle}</h3>

          <div class="contact-row">
            <div class="icon">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 8.6C9.10457 8.6 10 7.70457 10 6.6C10 5.49543 9.10457 4.6 8 4.6C6.89543 4.6 6 5.49543 6 6.6C6 7.70457 6.89543 8.6 8 8.6Z" stroke="#C9A227" stroke-width="1.3"/><path d="M8 14.6C10.6667 12 13.3333 9.6 13.3333 6.6C13.3333 3.6 10.9467 1.3 8 1.3C5.05333 1.3 2.66667 3.6 2.66667 6.6C2.66667 9.6 5.33333 12 8 14.6Z" stroke="#C9A227" stroke-width="1.3"/></svg>
            </div>
            <div>
              <div class="k">{c.addressLabel}</div>
              <div class="v">{c.address}</div>
            </div>
          </div>

          <div class="contact-row">
            <div class="icon">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="3.5" width="12" height="9" rx="1.4" stroke="#C9A227" stroke-width="1.3"/><path d="M2.6 4.2L8 8.4L13.4 4.2" stroke="#C9A227" stroke-width="1.3" stroke-linecap="round"/></svg>
            </div>
            <div>
              <div class="k">{c.emailLabel}</div>
              <div class="v"><a href="mailto:info@miu.mn">{c.email}</a></div>
            </div>
          </div>
        </div>

        <div class="form-card">
          <h3>{c.formTitle}</h3>

          <div class="alert alert-success" id="statusOk" hidden>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M8 12l3 3 5-6"/></svg>
            <div>{c.formSuccess}</div>
          </div>
          <div class="alert alert-danger" id="statusErr" hidden>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
            <div>{c.formError}</div>
          </div>
          <div class="alert alert-success" id="prefillNote" hidden>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M8 12l3 3 5-6"/></svg>
            <div>{c.prefillNote} <button type="button" id="prefillClear" style="background:none;border:none;text-decoration:underline;color:inherit;cursor:pointer;font:inherit;padding:0;">{c.prefillClear}</button></div>
          </div>

          <form method="POST" action="/contact.php">
            <input type="hidden" name="_next" value={nextPath} />
            <p style="position:absolute; left:-9999px;" aria-hidden="true">
              <label>Leave empty <input type="text" name="bot-field" tabindex="-1" autocomplete="off" /></label>
            </p>

            <div class="form-grid two">
              <div class="field">
                <label for="name">{c.formName}</label>
                <input id="name" name="name" type="text" required />
              </div>
              <div class="field">
                <label for="company">{c.formCompany}</label>
                <input id="company" name="company" type="text" />
              </div>
              <div class="field">
                <label for="email">{c.formEmail}</label>
                <input id="email" name="email" type="email" required />
              </div>
              <div class="field">
                <label for="phone">{c.formPhone}</label>
                <input id="phone" name="phone" type="tel" />
              </div>
            </div>

            <div class="field" style="margin-top:18px;">
              <label for="subject">{c.formSubject}</label>
              <select id="subject" name="subject">
                {c.formSubjectOptions.map((opt: string) => <option value={opt}>{opt}</option>)}
              </select>
            </div>

            <div class="field" style="margin-top:18px;">
              <label for="message">{c.formMessage}</label>
              <textarea id="message" name="message" required></textarea>
            </div>

            <div class="form-actions">
              <button class="btn btn-primary" type="submit">{c.formSubmit}</button>
              <span class="form-note">info@miu.mn</span>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ tiers: ex.tiers, stages: ex.stages, subjectOptions: c.formSubjectOptions }}>
  const params = new URLSearchParams(window.location.search);
  const ok = document.getElementById('statusOk');
  const err = document.getElementById('statusErr');
  if (params.get('sent') === '1' && ok) ok.hidden = false;
  if (params.get('error') === '1' && err) err.hidden = false;

  const STORAGE_KEY = 'miu_explorer';
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (raw) {
      const saved = JSON.parse(raw);
      const tier = tiers.find((t) => t.key === saved.tier);
      const stage = stages.find((s) => s.key === saved.stage);
      if (tier && stage) {
        const brand = (tier.brands.split(' · ')[0] || tier.brands).replace(/,.*/, '');
        const cta = stage.cta.replace('{brand}', brand);

        const messageEl = document.getElementById('message');
        if (messageEl && !messageEl.value) {
          messageEl.value = `${tier.title} — ${stage.label}\n${cta}`;
        }
        const subjectEl = document.getElementById('subject');
        if (subjectEl && subjectOptions[1]) {
          subjectEl.value = stage.key === 'tender' ? subjectOptions[1] : subjectOptions[0];
        }
        const note = document.getElementById('prefillNote');
        if (note) note.hidden = false;

        const clearBtn = document.getElementById('prefillClear');
        if (clearBtn) {
          clearBtn.addEventListener('click', () => {
            localStorage.removeItem(STORAGE_KEY);
            if (messageEl) messageEl.value = '';
            if (note) note.hidden = true;
          });
        }
      }
    }
  } catch (e) { /* localStorage unavailable -- non-fatal, form just starts empty */ }
</script>
